exports[`--help > prints help 1`] = `
---------- Context -----------
Working Directory: /ROOT/test/__fixtures__/main
Command: /ROOT/lib/cli.js --max-workers 1 --no-footer --help
---------- Stdout ------------
nadle [tasks...]

Execute one or more named tasks

Execution options:
      --parallel         Run all specified tasks in parallel regardless of their order, while still
                         respecting task dependencies.                    [boolean] [default: false]
  -x, --exclude          Tasks to exclude from execution                                     [array]
      --no-cache         Disable task caching. All tasks will be executed and their results will not
                         be stored                                        [boolean] [default: false]
      --clean-cache      Deletes all files in the cache directory. Can be used with --cache-dir to
                         specify a custom location                        [boolean] [default: false]
  -l, --list             List all available tasks                         [boolean] [default: false]
      --list-workspaces  List all available workspaces                    [boolean] [default: false]
  -m, --dry-run          Run specified tasks in dry run mode              [boolean] [default: false]
  -w, --watch            Re-run the requested tasks when their inputs change
                                                                          [boolean] [default: false]
      --explain          Explain why a task runs, what depends on it, and its inputs, instead of
                         executing                                                          [string]
      --since            Run only the requested tasks affected by changes since the given git ref
                                                                                            [string]
      --show-config      Print the resolved configuration                 [boolean] [default: false]
      --config-key       Path to a specific resolved configuration value, using dot/bracket notation
                                                                       [string] [default: undefined]
      --stacktrace       Print stacktrace on error                        [boolean] [default: false]

General options:
  -c, --config       Path to config file      [string] [default: <cwd>/nadle.config.{js,mjs,ts,mts}]
      --cache-dir    Directory to store task cache results
                                          [string] [default: <projectDir>/node_modules/.cache/nadle]
      --log-level    Set the logging level
                                  [string] [choices: "error", "log", "info", "debug"] [default: log]
      --min-workers  Minimum number of workers (integer or percentage)
                                                   [string] [default: Os.availableParallelism() - 1]
      --max-workers  Maximum number of workers (integer or percentage)
                                                   [string] [default: Os.availableParallelism() - 1]
      --footer       Enables the in-progress summary footer during task execution
                                                                 [boolean] [default: !isCI && isTTY]
      --summary      Print a summary of executed tasks at the end of the run
                                                                          [boolean] [default: false]
      --why          Explain each task's cache outcome (hit/miss and what changed)
                                                                          [boolean] [default: false]

Miscellaneous options:
  -h, --help     Show this help                                                            [boolean]
  -v, --version  Show version number                                                       [boolean]

Options:
      --graph     Print the task dependency graph instead of executing (tree or mermaid)
                                                           [string] [choices: "", "tree", "mermaid"]
      --reporter  Output reporter: 'default' (human) or 'agent' (compact, plain, for agents/scripts)
                                           [string] [choices: "default", "agent"] [default: default]

Examples:
  nadle test -- -u  Run the test task, passing -u through to its underlying command
`;
