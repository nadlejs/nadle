		"@types/yargs": "^17.0.35",
		"@vitest/expect": "^4.0.18",
		"fixturify": "^3.0.0",
		"knip": "^6.16.1",
		"serialize-javascript": "^7.0.5",
		"size-limit": "^12.1.0",
